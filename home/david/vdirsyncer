[general]
status_path = "/home/david/.local/share/vdirsyncer/status"

### Pairs

[pair calendar_caldav]
a = "calendar_caldav_remote"
b = "calendar_caldav_local"
collections = ["from a", "from b"]
conflict_resolution = "a wins"
metadata = ["displayname", "color"]

[pair calendar_google]
a = "calendar_google_remote"
b = "calendar_google_local"
collections = ["from a", "from b"]
conflict_resolution = "a wins"
metadata = ["displayname", "color"]


### Local storages

[storage calendar_caldav_local]
fileext = ".ics"
path = "/home/david/.calendars/caldav"
type = "filesystem"

[storage calendar_google_local]
fileext = ".ics"
path = "/home/david/.calendars/google"
type = "filesystem"

### Remote storages

[storage calendar_caldav_remote]
item_types = ["VEVENT"]
password.fetch = ["command", "secret-tool", "lookup", "service", "cloud.davidwild.ch", "username", "david"]
type = "caldav"
url = "https://cloud.davidwild.ch/caldav/"
username = "david"


[storage calendar_google_remote]
# if access token is expired delete google_token.json and run `vdirsyncer discover
# go to https://calendar.google.com/calendar/u/0/syncselect to manage google chalendars
type = "google_calendar"
token_file = "/home/david/.config/vdirsyncer/google_token.json"

# Use the .fetch suffix for these fields
client_id.fetch = ["command", "secret-tool", "lookup", "service", "biobrotmithonig@gmail.com", "auth", "client_id"]
client_secret.fetch = ["command", "secret-tool", "lookup", "service", "biobrotmithonig@gmail.com", "auth", "client_secret"]
#start_date = null
#end_date = null
item_types = ["VEVENT"]